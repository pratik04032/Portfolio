rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'pratikkumarjena04@gmail.com' && request.auth.token.email_verified == true;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt', 'status']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 150 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 2000 &&
             data.createdAt == request.time &&
             data.status == 'new';
    }

    match /messages/{messageId} {
      allow read: if isAdmin();
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      allow update, delete: if isAdmin();
    }
    
    match /test/{docId} {
      allow read: if true;
    }
  }
}
