{
  "entities": {
    "Message": {
      "title": "Contact Message",
      "description": "A message submitted through the contact form.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The sender's name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The sender's email address."
        },
        "message": {
          "type": "string",
          "description": "The content of the message."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the message was submitted."
        },
        "status": {
          "type": "string",
          "enum": ["new", "read", "archived"],
          "description": "The status of the message."
        }
      },
      "required": ["name", "email", "message", "createdAt", "status"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of contact messages."
    }
  }
}
